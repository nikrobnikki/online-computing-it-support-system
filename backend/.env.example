# ─── Server ───────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=production
CLIENT_URL=https://your-frontend.onrender.com

# ─── Database (MySQL / PlanetScale / Aiven) ───────────────────────────────────
DB_HOST=your-mysql-host.com
DB_PORT=3306
DB_NAME=kiratech_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
# Generate a strong secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=generate_a_64_char_random_hex_string_here
JWT_EXPIRES_IN=7d

# ─── Email (Gmail SMTP with App Password) ─────────────────────────────────────
# Get App Password: https://myaccount.google.com/apppasswords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_16_char_app_password
EMAIL_FROM=KIRATECH IT Support <your_email@gmail.com>

# ─── Admin Account ────────────────────────────────────────────────────────────
ADMIN_EMAIL=your_admin@gmail.com
ADMIN_PASSWORD=StrongPassword@123
ADMIN_NAME=Your Name

# ─── Stripe (Card Payments) ───────────────────────────────────────────────────
# Get keys: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx
STRIPE_CURRENCY=usd

# ─── East Africa Mobile Money ─────────────────────────────────────────────────
MPESA_TZ_BUSINESS_NUMBER=+255XXXXXXXXX
MPESA_TZ_ACCOUNT_REF=KIRATECH
AIRTEL_MERCHANT_NUMBER=+255XXXXXXXXX
TIGO_BILLER_MSISDN=+255XXXXXXXXX
MTN_MERCHANT_NUMBER=+255XXXXXXXXX

# ─── Binance / Crypto ─────────────────────────────────────────────────────────
BINANCE_MERCHANT_ID=your_binance_merchant_id
USDT_BEP20_ADDRESS=your_bep20_wallet_address
USDT_TRC20_ADDRESS=your_trc20_wallet_address
USDT_ERC20_ADDRESS=your_erc20_wallet_address
